# ==============================================================================
# AegisGuard.init - Global Monorepo Environment Variables
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. FRONTEND ENVIRONMENT (Next.js - frontend/)
# ------------------------------------------------------------------------------

# Core Settings
# Link: https://docs.initia.xyz/node-operators/networks (Use 'initiation-1' for testnet)
NEXT_PUBLIC_INITIA_CHAIN_ID=initiation-1

# Link: https://cloud.reown.com/ (Formerly WalletConnect Cloud. Get Project ID from your dashboard)
NEXT_PUBLIC_INTERWOVENKIT_PROJECT_ID=your_reown_walletconnect_project_id_here

# Backend Connection
# Local development backend URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Supabase Connectors (Client-safe)
# Link: https://supabase.com/dashboard/project/_/settings/api (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Smart Contract
# After running `forge create` or deployment scripts in /contracts/, paste your contract address here
NEXT_PUBLIC_AEGIS_GUARD_ADDRESS=0x0000000000000000000000000000000000000000


# ------------------------------------------------------------------------------
# 2. BACKEND ENVIRONMENT (FastAPI - backend/)
# ------------------------------------------------------------------------------

# Supabase Connectors (Server-side mutations)
# Link: https://supabase.com/dashboard/project/_/settings/api (Project Settings -> API -> service_role secret)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# AI / Threat Intelligence API Keys (If integrating external LLM)
# Link: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...


# ------------------------------------------------------------------------------
# 3. CONTRACTS ENVIRONMENT (Foundry - contracts/)
# ------------------------------------------------------------------------------

# Deployment Nodes
# Link: https://nodes.guru/testnets/initia or official Initia documentation for public RPCs
INITIA_RPC_URL=https://rpc-initia-testnet.nodes.guru

# Deployer Keys
# Instructions: Export your Private Key from MetaMask. NEVER check this real value into git!
PRIVATE_KEY=your_0x_private_key_here
