{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "typeRoots": ["../frontend/node_modules/@types"],
    "paths": {
      "playwright": ["../frontend/node_modules/playwright"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["dist"]
}
